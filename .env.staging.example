NODE_ENV=production
NEXTAUTH_URL=https://staging.your-domain.example
NEXTAUTH_SECRET=replace-with-long-staging-secret
DATABASE_URL=postgresql://user:password@staging-db:5432/cricket_ai_studio_staging?schema=public
GOOGLE_CLIENT_ID=your-staging-google-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-client-secret
OPENAI_API_KEY=sk-staging-key
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
AI_REQUEST_TIMEOUT_MS=120000

{
  "name": "cricket-ai-studio",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered cricket image generation workflow with quality prompt engineering for Cricket AI Studio.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "env:validate": "node scripts/validate-env.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run env:validate && npm run lint && npm run type-check && npm run test:coverage && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-slot": "latest",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "next-auth": "^4.24.14",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prisma": "^6.19.3",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "^4.1.9"
  }
}

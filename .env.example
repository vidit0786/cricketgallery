# App URL and auth secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# PostgreSQL database connection for Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cricket_ai_studio?schema=public

# Google Sign-In OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Required for AI analysis and image generation
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional AI model configuration
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=auto
AI_REQUEST_TIMEOUT_MS=120000
